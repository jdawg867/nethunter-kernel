# Kernel build output
out/
dist/
build/

# Ignore kernel source
kernel/*

# Allow tracking specific kernel config path
!kernel/private/
!kernel/private/devices/
!kernel/private/devices/google/
!kernel/private/devices/google/comet/
!kernel/private/devices/google/comet/comet_defconfig

# Bazel
bazel-*
bazel-bin
bazel-out
bazel-testlogs

# Repo tool
.repo/

# Kernel artifacts
*.img
*.dtb
*.dtbo
*.lz4

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.bak

# Editor files
.vscode/
.idea/

# Python cache
__pycache__/

# OS files
.DS_Store
